{
  "name": "SquishySmash",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/ServerScriptService/Server"
      }
    },

    "StarterPlayer": {
      "$properties": {
        "DevCameraOcclusionMode": "Invisicam"
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    }
  }
}
